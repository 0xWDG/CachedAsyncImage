{"identifier":{"url":"doc:\/\/CachedAsyncImage\/documentation\/CachedAsyncImage\/CachedAsyncImage","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"CachedAsyncImage"},{"text":"<","kind":"text"},{"text":"Content","kind":"genericParameter"},{"text":"> ","kind":"text"},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Content"},{"text":" : ","kind":"text"},{"text":"View","kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI4ViewP"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","text":"Overview","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This view uses the shared"},{"text":" ","type":"text"},{"type":"text","text":"doc:\/\/com.apple.documentation\/documentation\/Foundation\/URLSession"},{"type":"text","text":" "},{"type":"text","text":"instance to load an image from the specified URL, and then display it."},{"text":" ","type":"text"},{"text":"For example, you can display an icon that’s stored on a server:","type":"text"}]},{"type":"codeListing","code":["CachedAsyncImage(url: URL(string: \"https:\/\/example.com\/icon.png\"))","    .frame(width: 200, height: 200)"],"syntax":null},{"inlineContent":[{"text":"Until the image loads, the view displays a standard placeholder that","type":"text"},{"type":"text","text":" "},{"text":"fills the available space. After the load completes successfully, the view","type":"text"},{"type":"text","text":" "},{"type":"text","text":"updates to display the image. In the example above, the icon is smaller"},{"type":"text","text":" "},{"text":"than the frame, and so appears smaller than the placeholder.","type":"text"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can specify a custom placeholder using"},{"text":" ","type":"text"},{"type":"codeVoice","code":"init(url:scale:content:placeholder:)"},{"type":"text","text":". With this initializer, you can"},{"text":" ","type":"text"},{"type":"text","text":"also use the "},{"type":"codeVoice","code":"content"},{"text":" parameter to manipulate the loaded image.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"For example, you can add a modifier to make the loaded image resizable:"}],"type":"paragraph"},{"code":["CachedAsyncImage(url: URL(string: \"https:\/\/example.com\/icon.png\")) { image in","    image.resizable()","} placeholder: {","    ProgressView()","}",".frame(width: 50, height: 50)"],"syntax":null,"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"For this example, SwiftUI shows a ","type":"text"},{"type":"codeVoice","code":"ProgressView"},{"text":" first, and then the","type":"text"},{"type":"text","text":" "},{"text":"image scaled to fit in the specified frame:","type":"text"}]},{"inlineContent":[],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You can’t apply image-specific modifiers, like"},{"type":"text","text":" "},{"code":"Image\/resizable(capInsets:resizingMode:)","type":"codeVoice"},{"type":"text","text":", directly to an "},{"code":"AsyncImage","type":"codeVoice"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Instead, apply them to the "},{"code":"Image","type":"codeVoice"},{"text":" instance that your ","type":"text"},{"type":"codeVoice","code":"content"},{"text":" ","type":"text"},{"type":"text","text":"closure gets when defining the view’s appearance."}]}],"type":"aside","name":"Important","style":"important"},{"inlineContent":[{"text":"To gain more control over the loading process, use the","type":"text"},{"type":"text","text":" "},{"code":"init(url:scale:transaction:content:)","type":"codeVoice"},{"type":"text","text":" initializer, which takes a"},{"type":"text","text":" "},{"type":"codeVoice","code":"content"},{"type":"text","text":" closure that receives an "},{"code":"AsyncImagePhase","type":"codeVoice"},{"text":" to indicate","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the state of the loading operation. Return a view that’s appropriate"},{"type":"text","text":" "},{"type":"text","text":"for the current phase:"}],"type":"paragraph"},{"code":["CachedAsyncImage(url: URL(string: \"https:\/\/example.com\/icon.png\")) { phase in","    if let image = phase.image {","        image \/\/ Displays the loaded image.","    } else if phase.error != nil {","        Color.red \/\/ Indicates an error.","    } else {","        Color.blue \/\/ Acts as a placeholder.","    }","}"],"type":"codeListing","syntax":null}]}],"relationshipsSections":[{"identifiers":["doc:\/\/CachedAsyncImage\/s8SendableP","doc:\/\/CachedAsyncImage\/7SwiftUI4ViewP"],"kind":"relationships","title":"Conforms To","type":"conformsTo"}],"topicSections":[{"identifiers":["doc:\/\/CachedAsyncImage\/documentation\/CachedAsyncImage\/CachedAsyncImage\/init(url:urlCache:scale:)","doc:\/\/CachedAsyncImage\/documentation\/CachedAsyncImage\/CachedAsyncImage\/init(url:urlCache:scale:content:placeholder:)","doc:\/\/CachedAsyncImage\/documentation\/CachedAsyncImage\/CachedAsyncImage\/init(url:urlCache:scale:transaction:content:)"],"title":"Initializers"},{"title":"Instance Properties","identifiers":["doc:\/\/CachedAsyncImage\/documentation\/CachedAsyncImage\/CachedAsyncImage\/body"]},{"generated":true,"title":"Default Implementations","identifiers":["doc:\/\/CachedAsyncImage\/documentation\/CachedAsyncImage\/CachedAsyncImage\/View-Implementations"]}],"sections":[],"metadata":{"platforms":[{"unavailable":false,"deprecated":false,"beta":false,"name":"iOS","introducedAt":"15.0"},{"unavailable":false,"name":"macOS","beta":false,"introducedAt":"12.0","deprecated":false},{"deprecated":false,"name":"tvOS","unavailable":false,"introducedAt":"15.0","beta":false},{"introducedAt":"8.0","beta"