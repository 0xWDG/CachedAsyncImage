{"variants":[{"paths":["\/documentation\/cachedasyncimage\/cachedasyncimage"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"abstract":[{"text":"A view that asynchronously loads and displays an image.","type":"text"}],"relationshipsSections":[{"kind":"relationships","type":"conformsTo","identifiers":["doc:\/\/CachedAsyncImage\/s8SendableP","doc:\/\/CachedAsyncImage\/7SwiftUI4ViewP"],"title":"Conforms To"}],"kind":"symbol","identifier":{"url":"doc:\/\/CachedAsyncImage\/documentation\/CachedAsyncImage\/CachedAsyncImage","interfaceLanguage":"swift"},"metadata":{"platforms":[{"deprecated":false,"unavailable":false,"introducedAt":"15.0","name":"iOS","beta":false},{"introducedAt":"12.0","unavailable":false,"deprecated":false,"name":"macOS","beta":false},{"unavailable":false,"deprecated":false,"name":"tvOS","introducedAt":"15.0","beta":false},{"name":"watchOS","introducedAt":"8.0","beta":false,"deprecated":false,"unavailable":false}],"navigatorTitle":[{"kind":"identifier","text":"CachedAsyncImage"}],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"CachedAsyncImage"}],"externalID":"s:16CachedAsyncImageAAV","roleHeading":"Structure","role":"symbol","symbolKind":"struct","title":"CachedAsyncImage","modules":[{"name":"CachedAsyncImage"}]},"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"CachedAsyncImage"},{"text":"<","kind":"text"},{"text":"Content","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"typeIdentifier","text":"Content"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","text":"View","preciseIdentifier":"s:7SwiftUI4ViewP"}]}],"kind":"declarations"},{"content":[{"text":"Overview","type":"heading","anchor":"overview","level":2},{"inlineContent":[{"text":"This view uses the shared","type":"text"},{"type":"text","text":" "},{"text":"doc:\/\/com.apple.documentation\/documentation\/Foundation\/URLSession","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"instance to load an image from the specified URL, and then display it."},{"text":" ","type":"text"},{"type":"text","text":"For example, you can display an icon that’s stored on a server:"}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["CachedAsyncImage(url: URL(string: \"https:\/\/example.com\/icon.png\"))","    .frame(width: 200, height: 200)"]},{"inlineContent":[{"text":"Until the image loads, the view displays a standard placeholder that","type":"text"},{"type":"text","text":" "},{"text":"fills the available space. After the load completes successfully, the view","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"updates to display the image. In the example above, the icon is smaller"},{"text":" ","type":"text"},{"type":"text","text":"than the frame, and so appears smaller than the placeholder."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[]},{"inlineContent":[{"type":"text","text":"You can specify a custom placeholder using"},{"type":"text","text":" "},{"type":"codeVoice","code":"init(url:scale:content:placeholder:)"},{"text":". With this initializer, you can","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"also use the "},{"type":"codeVoice","code":"content"},{"type":"text","text":" parameter to manipulate the loaded image."},{"text":" ","type":"text"},{"type":"text","text":"For example, you can add a modifier to make the loaded image resizable:"}],"type":"paragraph"},{"type":"codeListing","syntax":null,"code":["CachedAsyncImage(url: URL(string: \"https:\/\/example.com\/icon.png\")) { image in","    image.resizable()","} placeholder: {","    ProgressView()","}",".frame(width: 50, height: 50)"]},{"inlineContent":[{"text":"For this example, SwiftUI shows a ","type":"text"},{"type":"codeVoice","code":"ProgressView"},{"type":"text","text":" first, and then the"},{"type":"text","text":" "},{"text":"image scaled to fit in the specified frame:","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[]},{"content":[{"type":"paragraph","inlineContent":[{"text":"You can’t apply image-specific modifiers, like","type":"text"},{"text":" ","type":"text"},{"code":"Image\/resizable(capInsets:resizingMode:)","type":"codeVoice"},{"type":"text","text":", directly to an "},{"code":"AsyncImage","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Instead, apply them to the "},{"type":"codeVoice","code":"Image"},{"type":"text","text":" instance that your "},{"code":"content","type":"codeVoice"},{"text":" ","type":"text"},{"text":"closure gets when defining the view’s appearance.","type":"text"}]}],"name":"Important","style":"important","type":"aside"},{"type":"paragraph","inlineContent":[{"text":"To gain more control over the loading process, use the","type":"text"},{"text":" ","type":"text"},{"code":"init(url:scale:transaction:content:)","type":"codeVoice"},{"type":"text","text":" initializer, which takes a"},{"type":"text","text":" "},{"type":"codeVoice","code":"content"},{"type":"text","text":" closure that receives an "},{"type":"codeVoice","code":"AsyncImagePhase"},{"type":"text","text":" to indicate"},{"text":" ","type":"text"},{"type":"text","text":"the state of the loading operation. Return a view that’s appropriate"},{"text":" ","type":"text"},{"text":"for the current phase:","type":"text"}]},{"code":["CachedAsyncImage(url: URL(string: \"https:\/\/example.com\/icon.png\")) { phase in","    if let image = phase.image {","        image \/\/ Displays the loaded image.","    } else if phase.error != nil {","        Color.red \/\/ Indicates an error.","    } else {","        Color.blue \/\/ Acts as a placeholder.","    }","}"],"type":"codeListing","syntax":null}],"kind":"content"}],"hierarchy