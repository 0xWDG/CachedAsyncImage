{"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"CachedAsyncImage"},{"kind":"text","text":"<"},{"text":"Content","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"kind":"text","text":" "},{"text":"Content","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"View","preciseIdentifier":"s:7SwiftUI4ViewP","kind":"typeIdentifier"}]}],"kind":"declarations"},{"content":[{"anchor":"overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This view uses the shared"},{"text":" ","type":"text"},{"text":"doc:\/\/com.apple.documentation\/documentation\/Foundation\/URLSession","type":"text"},{"text":" ","type":"text"},{"text":"instance to load an image from the specified URL, and then display it.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"For example, you can display an icon that’s stored on a server:"}]},{"syntax":null,"code":["CachedAsyncImage(url: URL(string: \"https:\/\/example.com\/icon.png\"))","    .frame(width: 200, height: 200)"],"type":"codeListing"},{"inlineContent":[{"text":"Until the image loads, the view displays a standard placeholder that","type":"text"},{"text":" ","type":"text"},{"text":"fills the available space. After the load completes successfully, the view","type":"text"},{"type":"text","text":" "},{"text":"updates to display the image. In the example above, the icon is smaller","type":"text"},{"type":"text","text":" "},{"text":"than the frame, and so appears smaller than the placeholder.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[]},{"inlineContent":[{"text":"You can specify a custom placeholder using","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"init(url:scale:content:placeholder:)"},{"type":"text","text":". With this initializer, you can"},{"type":"text","text":" "},{"text":"also use the ","type":"text"},{"code":"content","type":"codeVoice"},{"type":"text","text":" parameter to manipulate the loaded image."},{"text":" ","type":"text"},{"text":"For example, you can add a modifier to make the loaded image resizable:","type":"text"}],"type":"paragraph"},{"code":["CachedAsyncImage(url: URL(string: \"https:\/\/example.com\/icon.png\")) { image in","    image.resizable()","} placeholder: {","    ProgressView()","}",".frame(width: 50, height: 50)"],"syntax":null,"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For this example, SwiftUI shows a "},{"code":"ProgressView","type":"codeVoice"},{"text":" first, and then the","type":"text"},{"type":"text","text":" "},{"text":"image scaled to fit in the specified frame:","type":"text"}]},{"type":"paragraph","inlineContent":[]},{"name":"Important","type":"aside","style":"important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You can’t apply image-specific modifiers, like"},{"type":"text","text":" "},{"type":"codeVoice","code":"Image\/resizable(capInsets:resizingMode:)"},{"text":", directly to an ","type":"text"},{"type":"codeVoice","code":"AsyncImage"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Instead, apply them to the "},{"type":"codeVoice","code":"Image"},{"text":" instance that your ","type":"text"},{"type":"codeVoice","code":"content"},{"type":"text","text":" "},{"type":"text","text":"closure gets when defining the view’s appearance."}]}]},{"type":"paragraph","inlineContent":[{"text":"To gain more control over the loading process, use the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"init(url:scale:transaction:content:)"},{"type":"text","text":" initializer, which takes a"},{"type":"text","text":" "},{"type":"codeVoice","code":"content"},{"text":" closure that receives an ","type":"text"},{"type":"codeVoice","code":"AsyncImagePhase"},{"text":" to indicate","type":"text"},{"type":"text","text":" "},{"text":"the state of the loading operation. Return a view that’s appropriate","type":"text"},{"type":"text","text":" "},{"text":"for the current phase:","type":"text"}]},{"syntax":null,"code":["CachedAsyncImage(url: URL(string: \"https:\/\/example.com\/icon.png\")) { phase in","    if let image = phase.image {","        image \/\/ Displays the loaded image.","    } else if phase.error != nil {","        Color.red \/\/ Indicates an error.","    } else {","        Color.blue \/\/ Acts as a placeholder.","    }","}"],"type":"codeListing"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/cachedasyncimage\/cachedasyncimage"]}],"abstract":[{"type":"text","text":"A view that asynchronously loads and displays an image."}],"metadata":{"externalID":"s:16CachedAsyncImageAAV","navigatorTitle":[{"text":"CachedAsyncImage","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"CachedAsyncImage"}],"modules":[{"name":"CachedAsyncImage"}],"title":"CachedAsyncImage","platforms":[{"unavailable":false,"introducedAt":"15.0","beta":false,"deprecated":false,"name":"iOS"},{"unavailable":false,"beta":false,"deprecated":false,"introducedAt":"12.0","name":"macOS"},{"introducedAt":"15.0","beta":false,"deprecated":false,"name":"tvOS","unavailable":false},{"unavailable":false,"deprecated":false,"beta":false,"introducedAt":"8.0","name":"watchOS"}],"symbolKind":"struct","roleHeading":"Structure","role":"symbol"},"schemaVersion":{"minor":3,"major":0,"patch":0},"relationshipsSections":[{"type":"conformsTo","title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/CachedAsyncImage\/7SwiftUI4ViewP"]}],"sections":[],"identifier":{"url":"doc:\/\/CachedAsyncImage\/documentation\/CachedAsyncImage\/CachedAsyncImage","interfaceLanguage":"swift"},"kind":"symbol","topicSections":[{"title":"Initializers","identifi