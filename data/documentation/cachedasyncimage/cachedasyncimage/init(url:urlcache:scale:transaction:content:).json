{"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/CachedAsyncImage\/documentation\/CachedAsyncImage","doc:\/\/CachedAsyncImage\/documentation\/CachedAsyncImage\/CachedAsyncImage"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"text":"Loads and displays a modifiable image from the specified URL in phases.","type":"text"}],"identifier":{"url":"doc:\/\/CachedAsyncImage\/documentation\/CachedAsyncImage\/CachedAsyncImage\/init(url:urlCache:scale:transaction:content:)","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"init","kind":"keyword"},{"kind":"text","text":"("},{"kind":"externalParam","text":"url"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:10Foundation3URLV","text":"URL"},{"text":"?, ","kind":"text"},{"text":"urlCache","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSURLCache","kind":"typeIdentifier","text":"URLCache"},{"kind":"text","text":" = .shared, "},{"kind":"externalParam","text":"scale"},{"text":": ","kind":"text"},{"text":"CGFloat","kind":"typeIdentifier","preciseIdentifier":"s:14CoreFoundation7CGFloatV"},{"kind":"text","text":" = 1, "},{"text":"transaction","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Transaction","preciseIdentifier":"s:7SwiftUI11TransactionV"},{"text":" = Transaction(), ","kind":"text"},{"text":"@","kind":"attribute"},{"text":"ViewBuilder","preciseIdentifier":"s:7SwiftUI11ViewBuilderV","kind":"attribute"},{"kind":"text","text":" "},{"text":"content","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"@escaping","kind":"keyword"},{"text":" (","kind":"text"},{"preciseIdentifier":"s:7SwiftUI15AsyncImagePhaseO","text":"AsyncImagePhase","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Content","kind":"typeIdentifier"},{"text":")","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"name":"url","content":[{"type":"paragraph","inlineContent":[{"text":"The URL of the image to display.","type":"text"}]}]},{"name":"urlCache","content":[{"type":"paragraph","inlineContent":[{"text":"The URL cache for providing cached responses to requests within the session.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"The scale to use for the image. The default is ","type":"text"},{"type":"codeVoice","code":"1"},{"type":"text","text":". Set a"},{"text":" ","type":"text"},{"type":"text","text":"different value when loading images designed for higher resolution"},{"type":"text","text":" "},{"type":"text","text":"displays. For example, set a value of "},{"type":"codeVoice","code":"2"},{"text":" for an image that you","type":"text"},{"text":" ","type":"text"},{"text":"would name with the ","type":"text"},{"type":"codeVoice","code":"@2x"},{"text":" suffix if stored in a file on disk.","type":"text"}],"type":"paragraph"}],"name":"scale"},{"name":"transaction","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The transaction to use when the phase changes."}]}]},{"name":"content","content":[{"inlineContent":[{"type":"text","text":"A closure that takes the load phase as an input, and"},{"type":"text","text":" "},{"type":"text","text":"returns the view to display for the specified phase."}],"type":"paragraph"}]}]},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you set the asynchronous image’s URL to "},{"code":"nil","type":"codeVoice"},{"type":"text","text":", or after you set the"},{"text":" ","type":"text"},{"text":"URL to a value but before the load operation completes, the phase is","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"AsyncImagePhase\/empty"},{"type":"text","text":". After the operation completes, the phase"},{"type":"text","text":" "},{"type":"text","text":"becomes either "},{"type":"codeVoice","code":"AsyncImagePhase\/failure(_:)"},{"type":"text","text":" or"},{"text":" ","type":"text"},{"code":"AsyncImagePhase\/success(_:)","type":"codeVoice"},{"text":". In the first case, the phase’s","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"AsyncImagePhase\/error"},{"text":" value indicates the reason for failure.","type":"text"},{"type":"text","text":" "},{"text":"In the second case, the phase’s ","type":"text"},{"type":"codeVoice","code":"AsyncImagePhase\/image"},{"text":" property","type":"text"},{"type":"text","text":" "},{"text":"contains the loaded image. Use the phase to drive the output of the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"content"},{"text":" closure, which defines the view’s appearance:","type":"text"}]},{"type":"codeListing","code":["CachedAsyncImage(url: URL(string: \"https:\/\/example.com\/icon.png\")) { phase in","    if let image = phase.image {","        image \/\/ Displays the loaded image.","    } else if phase.error != nil {","        Color.red \/\/ Indicates an error.","    } else {","        Color.blue \/\/ Acts as a placeholder.","    }","}"],"syntax":null},{"inlineContent":[{"type":"text","text":"To add transitions when you change the URL, apply an identifier to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"AsyncImage"},{"text":".","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/cachedasyncimage\/cachedasyncimage\/init(url:urlcache:scale:transaction:content:)"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"externalID":"s:16CachedAsyncImageAAV3url0D5Cache5scale11transaction7contentAByxG10Foundation3URLVSg_So10NSURLCacheC04CoreI07CGFloatV7SwiftUI11TransactionVxAR0bC5PhaseOctcfc","role":"symbol","symbolKind":"init","roleHeading":"Initializer","platforms":[{"beta":false,"name":"iOS","introducedAt":"15.0","deprecated":false,"unavailable":false},{"deprecated":false,"beta":false,"unavailable":false,"introducedAt"