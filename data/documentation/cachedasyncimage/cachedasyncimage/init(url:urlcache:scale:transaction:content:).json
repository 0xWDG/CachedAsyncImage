nt":[{"inlineContent":[{"type":"text","text":"The URL of the image to display."}],"type":"paragraph"}],"name":"url"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The URL cache for providing cached responses to requests within the session."}]}],"name":"urlCache"},{"content":[{"inlineContent":[{"type":"text","text":"The scale to use for the image. The default is "},{"type":"codeVoice","code":"1"},{"type":"text","text":". Set a"},{"type":"text","text":" "},{"type":"text","text":"different value when loading images designed for higher resolution"},{"type":"text","text":" "},{"type":"text","text":"displays. For example, set a value of "},{"code":"2","type":"codeVoice"},{"type":"text","text":" for an image that you"},{"text":" ","type":"text"},{"text":"would name with the ","type":"text"},{"type":"codeVoice","code":"@2x"},{"type":"text","text":" suffix if stored in a file on disk."}],"type":"paragraph"}],"name":"scale"},{"name":"transaction","content":[{"inlineContent":[{"text":"The transaction to use when the phase changes.","type":"text"}],"type":"paragraph"}]},{"name":"content","content":[{"inlineContent":[{"type":"text","text":"A closure that takes the load phase as an input, and"},{"text":" ","type":"text"},{"type":"text","text":"returns the view to display for the specified phase."}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you set the asynchronous image’s URL to "},{"code":"nil","type":"codeVoice"},{"text":", or after you set the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"URL to a value but before the load operation completes, the phase is"},{"type":"text","text":" "},{"type":"codeVoice","code":"AsyncImagePhase\/empty"},{"text":". After the operation completes, the phase","type":"text"},{"type":"text","text":" "},{"text":"becomes either ","type":"text"},{"code":"AsyncImagePhase\/failure(_:)","type":"codeVoice"},{"type":"text","text":" or"},{"text":" ","type":"text"},{"type":"codeVoice","code":"AsyncImagePhase\/success(_:)"},{"type":"text","text":". In the first case, the phase’s"},{"text":" ","type":"text"},{"type":"codeVoice","code":"AsyncImagePhase\/error"},{"type":"text","text":" value indicates the reason for failure."},{"text":" ","type":"text"},{"type":"text","text":"In the second case, the phase’s "},{"type":"codeVoice","code":"AsyncImagePhase\/image"},{"text":" property","type":"text"},{"type":"text","text":" "},{"text":"contains the loaded image. Use the phase to drive the output of the","type":"text"},{"type":"text","text":" "},{"code":"content","type":"codeVoice"},{"type":"text","text":" closure, which defines the view’s appearance:"}]},{"code":["CachedAsyncImage(url: URL(string: \"https:\/\/example.com\/icon.png\")) { phase in","    if let image = phase.image {","        image \/\/ Displays the loaded image.","    } else if phase.error != nil {","        Color.red \/\/ Indicates an error.","    } else {","        Color.blue \/\/ Acts as a placeholder.","    }","}"],"type":"codeListing","syntax":null},{"inlineContent":[{"text":"To add transitions when you change the URL, apply an identifier to the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"AsyncImage"},{"text":".","type":"text"}],"type":"paragraph"}]}],"metadata":{"role":"symbol","modules":[{"name":"CachedAsyncImage"}],"symbolKind":"init","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"url"},{"text":": ","kind":"text"},{"text":"URL","preciseIdentifier":"s:10Foundation3URLV","kind":"typeIdentifier"},{"kind":"text","text":"?, "},{"text":"urlCache","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSURLCache","text":"URLCache"},{"text":", ","kind":"text"},{"text":"scale","kind":"externalParam"},{"kind":"text","te