e":"text"},{"text":" ","type":"text"},{"type":"text","text":"continues to display the placeholder. The following example loads"},{"type":"text","text":" "},{"type":"text","text":"and displays an icon from an example server:"}]},{"type":"codeListing","syntax":null,"code":["CachedAsyncImage(url: URL(string: \"https:\/\/example.com\/icon.png\"))"]},{"inlineContent":[{"type":"text","text":"If you want to customize the placeholder or apply image-specific"},{"type":"text","text":" "},{"type":"text","text":"modifiers — like "},{"type":"codeVoice","code":"Image\/resizable(capInsets:resizingMode:)"},{"text":" —","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to the loaded image, use the "},{"type":"codeVoice","code":"init(url:scale:content:placeholder:)"},{"type":"text","text":" "},{"type":"text","text":"initializer instead."}],"type":"paragraph"}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/CachedAsyncImage\/documentation\/CachedAsyncImage\/CachedAsyncImage\/init(url:urlCache:scale:)"},"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"text":"Loads and displays an image from the specified URL.","type":"text"}],"sections":[],"kind":"symbol","references":{"doc://CachedAsyncImage/documentation/CachedAsyncImage/CachedAsyncImage/init(url:urlCache:scale:)":{"abstract":[{"type":"text","text":"Loads and displays an image from the specified URL."}],"role":"symbol","identifier":"doc:\/\/CachedAsyncImage\/documentation\/CachedAsyncImage\/CachedAsyncImage\/init(url:urlCache:scale:)","url":"\/documentation\/cachedasyncimage\/cachedasyncimage\/init(url:urlcache:scale:)","kind":"symbol","type":"topic","fragments":[{"text":"init","kind":"identifier"},{"kind":"text","text":"("},{"text":"url","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"URL","preciseIdentifier":"s:10Foundation3URLV"},{"text":"?, ","kind":"text"},{"text":"urlCache","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"t