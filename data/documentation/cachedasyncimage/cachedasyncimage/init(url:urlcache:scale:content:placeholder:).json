ragraph"}]}]},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"text":"Until the image loads, SwiftUI displays the placeholder view that","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"you specify. When the load operation completes successfully, SwiftUI"},{"text":" ","type":"text"},{"type":"text","text":"updates the view to show content that you specify, which you"},{"type":"text","text":" "},{"text":"create using the loaded image. For example, you can show a green","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"placeholder, followed by a tiled version of the loaded image:"}],"type":"paragraph"},{"syntax":null,"code":["CachedAsyncImage(url: URL(string: \"https:\/\/example.com\/icon.png\")) { image in","    image.resizable(resizingMode: .tile)","} placeholder: {","    Color.green","}"],"type":"codeListing"},{"inlineContent":[{"text":"If the load operation fails, SwiftUI continues to display the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"placeholder. To be able to display a different view on a load error,"},{"type":"text","text":" "},{"type":"text","text":"use the "},{"type":"codeVoice","code":"init(url:scale:transaction:content:)"},{"type":"text","text":" initializer instead."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/CachedAsyncImage\/documentation\/CachedAsyncImage","doc:\/\/CachedAsyncImage\/documentation\/CachedAsyncImage\/CachedAsyncImage"]]},"kind":"symbol","sections":[],"metadata":{"role":"symbol","symbolKind":"init","fragments":[{"text":"init","kind":"identifier"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"I"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"P"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"url"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:10Foundation3URLV","kind":"typeIdentifier","text":"URL"},{"text":"?, ","kind":"text"},{"kind":"externalParam"